# ══════════════════════════════════════════════════════════════
# JARVIS v8 — COMPLETE ENV VARIABLES
# Vercel Dashboard > Settings > Environment Variables mein add karo
# ══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# 🤖 AI PROVIDERS (Priority chain — #1 se start, fallback)
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=                    # groq.com — FREE 14,400/day (Flash mode)
GEMINI_API_KEY=                  # aistudio.google.com — FREE 1,500/day (Deep mode)
MISTRAL_API_KEY=                 # console.mistral.ai — FREE tier
OPENROUTER_API_KEY=              # openrouter.ai — FREE models available
# NOTE: Pollinations is always-on fallback — no key needed

# ─────────────────────────────────────────────────────────────
# 🔧 TOOLS & DATA
# ─────────────────────────────────────────────────────────────
NEWS_API_KEY=                    # newsapi.org — FREE 100/day
NASA_API_KEY=DEMO_KEY            # api.nasa.gov — FREE unlimited (DEMO_KEY works!)
WOLFRAM_APP_ID=                  # wolframalpha.com/api — FREE 2,000/month

# ─────────────────────────────────────────────────────────────
# 🎵 MUSIC
# ─────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=               # developer.spotify.com — FREE
SPOTIFY_CLIENT_SECRET=           # developer.spotify.com — FREE
LASTFM_API_KEY=                  # last.fm/api — FREE unlimited
# NOTE: Deezer works without any key!

# ─────────────────────────────────────────────────────────────
# 📺 VIDEO
# ─────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=                 # console.cloud.google.com — FREE 10,000 units/day

# ─────────────────────────────────────────────────────────────
# 💬 MESSAGING
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=              # BotFather (@BotFather on Telegram) — FREE
TELEGRAM_CHAT_ID=                # Your Telegram user/group ID — FREE
DISCORD_WEBHOOK_URL=             # Discord channel > Integrations > Webhook — FREE
WHATSAPP_TOKEN=                  # Meta Business — paid per msg after free tier
WHATSAPP_PHONE_ID=               # Meta Business account
WHATSAPP_TO=                     # Your WhatsApp number with country code

# ─────────────────────────────────────────────────────────────
# 📅 PRODUCTIVITY
# ─────────────────────────────────────────────────────────────
GOOGLE_ACCESS_TOKEN=             # Google OAuth — FREE (Calendar + Drive + Gmail)
NOTION_API_KEY=                  # notion.so/my-integrations — FREE
NOTION_DATABASE_ID=              # Notion database ID from URL
GITHUB_TOKEN=                    # github.com/settings/tokens — FREE (optional, raises limit)

# ─────────────────────────────────────────────────────────────
# 🎬 ENTERTAINMENT
# ─────────────────────────────────────────────────────────────
TMDB_API_KEY=                    # themoviedb.org/settings/api — FREE 1,000/day
GIPHY_API_KEY=                   # developers.giphy.com — FREE 100/hr

# ─────────────────────────────────────────────────────────────
# 🖼️ MEDIA / PHOTOS
# ─────────────────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=             # unsplash.com/developers — FREE 50/hr
PEXELS_API_KEY=                  # pexels.com/api — FREE 200/hr
PIXABAY_API_KEY=                 # pixabay.com/api — FREE (also works without key)

# ─────────────────────────────────────────────────────────────
# 💰 FINANCE
# ─────────────────────────────────────────────────────────────
ALPHA_VANTAGE_KEY=               # alphavantage.co — FREE 25/day
# NOTE: NSE/Yahoo Finance works without key!

# ─────────────────────────────────────────────────────────────
# 🤖 AI TOOLS
# ─────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=              # elevenlabs.io — FREE 10,000 chars/month
STABILITY_API_KEY=               # stability.ai — FREE 25 credits/month
HUGGINGFACE_TOKEN=               # huggingface.co/settings/tokens — FREE

# ─────────────────────────────────────────────────────────────
# 📰 NEWS
# ─────────────────────────────────────────────────────────────
GNEWS_API_KEY=                   # gnews.io — FREE 100/day

# ─────────────────────────────────────────────────────────────
# ☁️ STORAGE & SYNC (Optional — app works without these)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=        # supabase.com — FREE 500MB
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # supabase.com
NEXT_PUBLIC_UPSTASH_VECTOR_URL=  # upstash.com — FREE 10k vectors
NEXT_PUBLIC_UPSTASH_VECTOR_TOKEN=
CLOUDFLARE_R2_ACCOUNT_ID=        # cloudflare.com/r2 — FREE 10GB/month
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=jarvis-media
NEXT_PUBLIC_R2_PUBLIC_URL=

# ══════════════════════════════════════════════════════════════
# MINIMUM TO RUN: Just GROQ_API_KEY — rest is optional!
# EVEN WITH NO KEYS: Pollinations fallback + 15+ no-key tools
# ══════════════════════════════════════════════════════════════
